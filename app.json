{
  "expo": {
    "name": "Merke und Male",
    "slug": "merke-und-male",
    "version": "1.3.5",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "userInterfaceStyle": "light",
    "scheme": "merkeundmale",
    "primaryColor": "#60D5FA",
    "description": "Gedächtnistraining für Kinder: Merken, Malen, Lernen! Eine pädagogisch wertvolle App für spielerisches Lernen.",
    "privacy": "public",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#60D5FA"
    },
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "ios": {
      "icon": "./assets/icons/app-icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.s540d.merkeundmale",
      "buildNumber": "2",
      "appStoreUrl": "https://apps.apple.com/app/merke-und-male/id[TBD]",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "CFBundleDisplayName": "Merke und Male"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#60D5FA"
      },
      "package": "com.s540d.merkeundmale",
      "permissions": [],
      "versionCode": 51,
      "newArchEnabled": false,
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.s540d.merkeundmale",
      "privacyPolicy": "https://s540d.github.io/DrawFromMemory/PRIVACY_POLICY.html"
    },
    "web": {
      "favicon": "./assets/icons/favicon.png",
      "output": "single",
      "baseUrl": "/DrawFromMemory/",
      "name": "Merke und Male",
      "shortName": "Merke & Male",
      "description": "Gedächtnistraining für Kinder: Merken, Malen, Lernen!",
      "themeColor": "#60D5FA",
      "backgroundColor": "#60D5FA",
      "lang": "de",
      "icons": [
        {
          "src": "/DrawFromMemory/apple-touch-icon.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "@sentry/react-native",
        {
          "uploadNativeSymbols": false,
          "autoUploadNativeSymbols": false,
          "url": "https://sentry.io/"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "00db964a-4f5d-4765-8b03-a9b6bb0ef963"
      }
    },
    "runtimeVersion": {
      "policy": "nativeVersion"
    },
    "owner": "devsven"
  }
}
