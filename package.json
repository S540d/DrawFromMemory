{
  "name": "merke-und-male",
  "version": "1.7.2",
  "main": "expo-router/entry",
  "homepage": "https://s540d.github.io/DrawFromMemory/",
  "repository": {
    "type": "git",
    "url": "https://github.com/S540d/DrawFromMemory.git"
  },
  "bugs": {
    "url": "https://github.com/S540d/DrawFromMemory/issues"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "build:android": "eas build --platform android --profile production",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:doctor": "bash scripts/build-doctor.sh",
    "build:android:local": "bash scripts/build-local.sh preview",
    "build:android:local:preview": "bash scripts/build-local.sh preview",
    "build:android:local:production": "bash scripts/build-local.sh production",
    "build:ios": "eas build --platform ios --profile production",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "validate:svg-counts": "node scripts/validate-svg-counts.js",
    "validate": "./scripts/validate-release.sh",
    "prepare-release": "./scripts/prepare-release.sh",
    "deploy:ghpages": "./scripts/deploy-ghpages.sh",
    "prepare": "husky install",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/metro-runtime": "~55.0.6",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.6",
    "expo-asset": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-file-system": "~55.0.24",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linear-gradient": "~55.0.8",
    "expo-localization": "~55.0.8",
    "expo-router": "~55.0.5",
    "expo-sharing": "~55.0.21",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "~55.0.1",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-svg-web": "^1.0.9",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "~29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expo-linking": "~55.0.7",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "react-test-renderer": "19.2.0",
    "ws": "^8.21.0"
  },
  "private": true
}
